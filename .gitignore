```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version
.python_history
.pytest_cache/
.mypy_cache/
.coverage
coverage/
htmlcov/

# Compiled and build artifacts
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Distribution / packaging
dist/
build/
*.egg
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```